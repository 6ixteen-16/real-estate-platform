# ============================================================
# PRESTIGE PROPERTIES — ENVIRONMENT VARIABLES
# Copy this file to .env.local and fill in your values
# NEVER commit .env.local to version control
# ============================================================

# ---- App ----
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=your-nextauth-secret-minimum-32-characters

# ---- Database (Supabase) ----
# Get from: https://supabase.com → Project Settings → Database
DATABASE_URL=postgresql://postgres:[password]@db.[project-ref].supabase.co:5432/postgres?pgbouncer=true&connection_limit=1
DIRECT_URL=postgresql://postgres:[password]@db.[project-ref].supabase.co:5432/postgres

# ---- Cloudinary ----
# Get from: https://cloudinary.com → Dashboard
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret
NEXT_PUBLIC_CLOUDINARY_UPLOAD_PRESET=your-unsigned-upload-preset

# ---- Email (Resend or Gmail SMTP) ----
# Resend: https://resend.com → API Keys
# Set EMAIL_HOST=smtp.resend.com, EMAIL_USER=resend, EMAIL_PASS=re_xxx
# Gmail: EMAIL_HOST=smtp.gmail.com, EMAIL_PORT=587, EMAIL_USER=your@gmail.com, EMAIL_PASS=app-password
EMAIL_HOST=smtp.resend.com
EMAIL_PORT=587
EMAIL_USER=resend
EMAIL_PASS=re_your_resend_api_key
EMAIL_FROM="Prestige Properties <noreply@your-domain.com>"
ADMIN_EMAIL=admin@your-domain.com
RESEND_API_KEY=re_your_resend_api_key

# ---- Cloudflare Turnstile ----
# Get from: https://dash.cloudflare.com → Turnstile
NEXT_PUBLIC_CLOUDFLARE_TURNSTILE_SITE_KEY=0x0000000000000000000000
CLOUDFLARE_TURNSTILE_SECRET=0x0000000000000000000000000000000000000000

# ---- Upstash Redis (Rate Limiting) ----
# Get from: https://upstash.com → Redis → REST API
UPSTASH_REDIS_REST_URL=https://your-instance.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-token

# ---- Analytics ----
NEXT_PUBLIC_GA4_ID=G-XXXXXXXXXX

# ---- WhatsApp ----
NEXT_PUBLIC_WHATSAPP_NUMBER=1234567890

# ---- Sentry (Error Tracking) ----
# Get from: https://sentry.io → Project → DSN
NEXT_PUBLIC_SENTRY_DSN=https://xxx@xxx.ingest.sentry.io/xxx
SENTRY_ORG=your-org
SENTRY_PROJECT=your-project

# ---- Bundle Analyzer ----
ANALYZE=false
